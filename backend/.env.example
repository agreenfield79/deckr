IBMCLOUD_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=
WATSONX_API_VERSION=2024-05-31
WORKSPACE_ROOT=./workspace_root/projects/default
ALLOWED_ORIGINS=http://localhost:5173
ENABLE_EXTRACTION=false
# Set ENABLE_EXTRACTION=true after Step 14.1 fixes are confirmed.
# PDF text extracted via pypdf (local, no API call); stored as {file}.extracted.json sidecars.
ENABLE_EMBEDDINGS=false
# Set ENABLE_EMBEDDINGS=true after extraction is working and workspace has indexed content.
# Uses ibm/slate-125m-english-rtrvr via watsonx REST API for semantic chunk retrieval.
USE_ORCHESTRATE=false
SESSION_SECRET=
LOG_LEVEL=INFO

# Phase 12 — Orchestrate (uncomment and fill when activating)
# ORCHESTRATE_BASE_URL=https://api.ca-tor.watson-orchestrate.cloud.ibm.com/instances/<instance-id>
# ORCHESTRATE_API_KEY=<service-credential-apikey>
# ORCHESTRATE_AGENT_ID_EXTRACTION=    # Phase 19b — set after deploying financial_data_extraction_agent
# ORCHESTRATE_AGENT_ID_INDUSTRY=      # Phase 20  — set after deploying industry_analysis_agent
# ORCHESTRATE_AGENT_ID_COLLATERAL=    # Phase 21  — set after deploying collateral_agent
# ORCHESTRATE_AGENT_ID_GUARANTOR=     # Phase 22  — set after deploying guarantor_agent
# ORCHESTRATE_AGENT_ID_PACKAGING=
# ORCHESTRATE_AGENT_ID_FINANCIAL=
# ORCHESTRATE_AGENT_ID_RISK=
# ORCHESTRATE_AGENT_ID_COORDINATION=
# ORCHESTRATE_AGENT_ID_REVIEW=
# ORCHESTRATE_AGENT_ID_INTERPRETER=

# Step 12.7 — IBM Cloud Object Storage (workspace storage migration)
# Set USE_COS=true to activate COS storage instead of local filesystem
# USE_COS=false
# COS_ENDPOINT_URL=https://s3.us-south.cloud-object-storage.appdomain.cloud
# COS_BUCKET_NAME=deckr-workspace
# COS_API_KEY=<apikey from COS service credential>
# COS_INSTANCE_CRN=<resource_instance_id from COS service credential>

# Phase 15 — Tool Service
# SERPAPI_KEY=             # Required for search_web tool; free tier at serpapi.com (100 searches/month)

# Phase 15 — watsonx Document Understanding (OCR for scanned PDFs)
# ENABLE_WDU=false         # Set true after provisioning WDU service
# WDU_API_KEY=             # IAM API key for WDU service instance
# WDU_URL=                 # WDU service URL, e.g. https://api.us-south.document-understanding.watson.cloud.ibm.com

# ── Phase 3: Storage / Database (D-1: SQLite default; swap DB_URL for PostgreSQL when Docker is up) ──
STORAGE_BACKEND=local
DB_URL=sqlite:///./data/deckr.db
# DB_URL=postgresql://deckr:deckr@localhost:5432/deckr  # swap in when Docker is running

MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=deckr

NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
# NEO4J_PASSWORD=          # SENSITIVE — never store actual value here; set in .env only

NGROK_DOMAIN=
MULTI_DEAL_MODE=false

# ── Phase 3: Database Refactor Gate ──
# Set to true to activate refactored service paths as each Phase 3 step is deployed.
# Keep false until Phase 3A gate is fully cleared and each step is validated.
SCHEMA_REFACTOR_ENABLED=false